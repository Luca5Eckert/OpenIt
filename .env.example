# ===========================================
# Libera.ai - Environment Variables Template
# ===========================================
# Copy this file to .env and fill in the values
# NEVER commit .env with real credentials
# ===========================================

# =====================
# Database Configuration
# =====================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=libera_db
DB_USER=libera_user
DB_PASSWORD=your_secure_password_here
DB_ROOT_PASSWORD=your_root_password_here

# =====================
# Application
# =====================
APP_PORT=8080

# =====================
# Mercado Pago Integration
# =====================
# Use TEST credentials for development (tokens starting with TEST-)
# Use LIVE credentials (APP_USR-) for production
# Get your credentials at: https://www.mercadopago.com.br/developers/panel/credentials

# Access Token - NEVER hardcode this in source code
MP_ACCESS_TOKEN=TEST-your-access-token-here

# Public Key (for frontend if needed)
MP_PUBLIC_KEY=TEST-your-public-key-here

# Default payer ID for test payments
MP_DEFAULT_PAYER_ID=your_test_payer_id

# Webhook URL - Must be publicly accessible (use ngrok for development)
# Example: https://your-ngrok-subdomain.ngrok-free.app/payments/webhook
WEBHOOK_URL=https://your-domain.ngrok-free.app/payments/webhook

# =====================
# ngrok (for webhook development)
# =====================
NGROK_AUTHTOKEN=your_ngrok_auth_token

# =====================
# Node-RED Integration
# =====================
NODE_HOST=localhost
NODE_PORT=1880
NODE_RED_PORT=1880
