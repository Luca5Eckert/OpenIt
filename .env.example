# ====================================
# Libera.ai - Environment Configuration
# ====================================
# Copy this file to .env and configure your values

# Database Configuration
DB_ROOT_PASSWORD=your_secure_root_password
DB_NAME=libera_db
DB_USER=libera_user
DB_PASSWORD=your_secure_password

# Mercado Pago Integration
# Get your token at: https://www.mercadopago.com.br/developers/panel/app
#
# IMPORTANT: Use TEST credentials for development/testing!
# - TEST token: Starts with 'TEST-' (e.g., TEST-1234567890123456-...)
# - PRODUCTION token: Starts with 'APP_USR-' (for production use only)
#
# Using PRODUCTION credentials in a test environment will cause:
# "Unauthorized use of live credentials" error (HTTP 401)
#
# To get TEST credentials:
# 1. Go to https://www.mercadopago.com.br/developers/panel/app
# 2. Select your application
# 3. In "Credenciais de teste" section, copy the Access Token
MP_ACCESS_TOKEN=TEST-your_test_access_token

# Node.js IoT Orchestrator (optional)
# Used for ESP32 gate control integration
NODE_HOST=172.17.0.1
NODE_PORT=3000

# Ngrok (optional - for webhook testing)
# NGROK_AUTHTOKEN=your_ngrok_token
